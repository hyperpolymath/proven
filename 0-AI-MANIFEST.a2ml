; SPDX-License-Identifier: PMPL-1.0-or-later
; SPDX-FileCopyrightText: 2026 Jonathan D.A. Jewell (hyperpolymath)
;
; 0-AI-MANIFEST.a2ml — Universal AI entry point for proven
; Media-Type: application/a2ml

; THIS FILE MUST BE READ FIRST BY ALL AI AGENTS

(manifest
  (identity
    (name "proven")
    (full-name "proven — Formally Verified Safety Library")
    (version "0.9.x")
    (repo "https://github.com/hyperpolymath/proven")
    (license "PMPL-1.0-or-later")
    (author "Jonathan D.A. Jewell <j.d.a.jewell@open.ac.uk>"))

  (purpose
    "Formally verified safety library: 258 Idris2 modules with dependent types,
     Zig FFI bridge (pure ABI layer), and 120+ language binding targets.
     ALL computation happens in Idris2. Bindings are thin FFI wrappers ONLY.")

  ;; ===================================================================
  ;; CONTEXT TIERS
  ;; ===================================================================

  (context-tiers
    ; Tier 0 (always load): This file + .claude/CLAUDE.md — orientation only
    ; Tier 1 (load if working on code): README.adoc, EXPLAINME.adoc, proven.ipkg
    ; Tier 2 (load on demand): .machine_readable/6a2/*.a2ml, docs/
    ; Tier 3 (never load unless asked): tests/, benchmarks/, generated/
    ;
    ; DO NOT READ unless specifically asked:
    ;   tests/          — test files (run them, don't read them)
    ;   benchmarks/     — performance benchmarks
    ;   generated/      — auto-generated code
    ;   build/          — Idris2 build output
    ;   *.lock          — lock files
    ;   bindings/*/target/ — binding build artifacts
    )

  ;; ===================================================================
  ;; CANONICAL LOCATIONS
  ;; ===================================================================

  (canonical-locations
    (ai-manifest     "0-AI-MANIFEST.a2ml"           "THIS FILE")
    (ai-instructions ".claude/CLAUDE.md"             "Claude-specific patterns")
    (state           ".machine_readable/6a2/STATE.a2ml")
    (meta            ".machine_readable/6a2/META.a2ml")
    (ecosystem       ".machine_readable/6a2/ECOSYSTEM.a2ml")
    (bot-directives  ".bot_directives/")
    (contractiles    "contractiles/"))

  ;; ===================================================================
  ;; ARCHITECTURE (CRITICAL — read this)
  ;; ===================================================================

  (architecture
    (principle "Idris2 is the SOLE computation layer — ALL safety logic lives in src/Proven/")
    (layers
      (idris2  "src/Proven/"    "258 modules — the source of truth")
      (zig-ffi "ffi/zig/"       "PURE ABI layer — no safety logic here")
      (bindings "bindings/"     "120+ thin FFI wrappers — CALL Idris, NEVER reimplement"))
    (banned "believe_me is BANNED — --total flag enforced")
    (banned "NEVER reimplement algorithms in bindings"))

  ;; ===================================================================
  ;; STRUCTURE OVERVIEW
  ;; ===================================================================

  (structure
    "proven/
     ├── 0-AI-MANIFEST.a2ml         # THIS FILE
     ├── proven.ipkg                 # Main Idris2 package (258 modules)
     ├── proven-ffi.ipkg             # FFI-only package
     ├── src/Proven/                 # 104 Safe* modules + FFI + ECHIDNA
     ├── ffi/zig/                    # Zig FFI bridge (pure ABI layer)
     ├── bindings/                   # 120+ language binding targets
     ├── apps/proven-bgp/            # BGP implementation (DONE)
     ├── contractiles/               # Security contracts
     ├── .bot_directives/            # Bot orchestration
     └── .machine_readable/          # State, meta, ecosystem")

  ;; ===================================================================
  ;; CRITICAL INVARIANTS
  ;; ===================================================================

  (critical-invariants
    (rule "Idris2 is the sole computation layer — Zig is pure ABI, bindings are thin wrappers")
    (rule "believe_me is BANNED — --total flag enforced on all modules")
    (rule "NEVER reimplement algorithms in bindings — CALL Idris via FFI only")
    (rule "SCM files ONLY in .machine_readable/ — never in root")
    (rule "PMPL-1.0-or-later on all source files")
    (rule "Author: Jonathan D.A. Jewell <j.d.a.jewell@open.ac.uk>"))

  ;; ===================================================================
  ;; SESSION LIFECYCLE
  ;; ===================================================================

  (lifecycle
    (on-enter
      (step "Read THIS file first")
      (step "Read .claude/CLAUDE.md for detailed constraints")
      (step "Read .machine_readable/6a2/STATE.a2ml for current status")
      (step "Understand: Idris2 -> Zig FFI -> Bindings"))

    (on-exit
      (step "Update .machine_readable/6a2/STATE.a2ml if changes made")
      (step "Verify no reimplemented logic in bindings")
      (step "Summarise outcomes")))

  (format-meta
    (version "2.1.0")
    (media-type "application/a2ml")
    (created "2026-02-22")
    (last-updated "2026-03-24")
    (maintained-by "Jonathan D.A. Jewell / hyperpolymath")
    (protocol "https://github.com/hyperpolymath/0-ai-gatekeeper-protocol")))
