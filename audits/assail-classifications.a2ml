    (file "bindings/nix/flake.nix")
    (category "SupplyChain")
    (classification "resolved-file-removed")
    (audit "audits/audit-track-c-2026-06-23.md §SupplyChain")
    (rationale "bindings/nix/flake.nix removed during the estate Nix→Guix migration (commit ee62f7e); the surviving bindings/nix/default.nix is a consumer-facing expression and was not flagged for unpinned flake inputs.")))
