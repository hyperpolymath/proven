-- SPDX-License-Identifier: MPL-2.0
-- Copyright (c) 2026 Jonathan D.A. Jewell (hyperpolymath) <jonathan.jewell@open.ac.uk>
--
-- Property-test suite for the proven library.
--
-- Build pre-requisite: the `proven` library must be installed first
-- (`idris2 --install proven.ipkg`) so the `depends = proven` resolution
-- succeeds.
--
-- This wires the previously-orphan `tests/properties/` directory to CI.
-- See `docs/proof-debt-triage.md` §8 Day 1 for the rationale.

package proven-tests

version = 1.1.0
authors = "Jonathan D.A. Jewell (hyperpolymath) <jonathan.jewell@open.ac.uk>"
license = "MPL-2.0"
brief = "Property-test suite for proven (29 modules, runtime + type-level assertions)"

sourcedir = "tests/properties"
builddir = "build/tests"

modules = Main
        , SafeArgsProps
        , SafeBase64Props
        , SafeCommandProps
        , SafeContentTypeProps
        , SafeCookieProps
        , SafeCryptoProps
        , SafeCurrencyProps
        , SafeDateTimeProps
        , SafeEmailProps
        , SafeEnvProps
        , SafeFileProps
        , SafeHeaderProps
        , SafeHexProps
        , SafeHtmlProps
        , SafeJsonProps
        , SafeJWTProps
        , SafeMathProps
        , SafeNetworkProps
        , SafePasswordProps
        , SafePathProps
        , SafePhoneProps
        , SafeRegexProps
        , SafeSQLProps
        , SafeStringProps
        , SafeTOMLProps
        , SafeUrlProps
        , SafeUUIDProps
        , SafeXMLProps
        , SafeYAMLProps

main = Main

executable = proven_tests

depends = base    >= 0.6.0
        , contrib >= 0.6.0
        , proven  >= 1.1.0
